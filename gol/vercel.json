{
  "version": 2,
  "builds": [
    {
      "src": "gol/wsgi.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb", "runtime": "python3.13" }
    },
    {
      "src": "build.sh",
      "use": "@vercel/static-build",
      "config": { "distDir": "staticfiles" }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "gol/wsgi.py"
    },
    {
      "src": "/admin/(.*)",
      "dest": "gol/wsgi.py"
    },
    {
      "src": "/(.*)",
      "dest": "staticfiles/index.html"
    }
  ]
}
