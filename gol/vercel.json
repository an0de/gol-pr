{
  "version": 2,
  "builds": [
    {
      "src": "gol/wsgi.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb", "runtime": "python3.13" }
    },
    {
      "src": "build.sh",
      "use": "@vercel/static-build",
      "config": { "distDir": "staticfiles" }
    }
  ],
  "routes": [
    {
      "src": "/static/(dist|admin|rest_framework)/(.*)",
      "dest": "$1/$2"
    },
    {
      "src": "/(.*)",
      "dest": "gol/wsgi.py"
    }
  ]
}
